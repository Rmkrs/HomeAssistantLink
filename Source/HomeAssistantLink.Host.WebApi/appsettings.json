{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        },
        "EventLog": {
            "LogLevel": {
                "Default": "Information"
            }
        }
    },
    "AllowedHosts": "*",
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://localhost:5421"
            }
        }
    },
    "HomeAssistantLink": {
        "HomeAssistant": {
            "Host": "<enter-your-homeassistant-url-here>",
            "ApiKey": "<enter-your-homeassistant-rest-apikey-here>"
        },
        "Api": {
            "Key": "<enter-your-local-api-key-here>"
        },
        "Monitors": {
            "WebCamMonitor": {
                "EntityId": "<entityid-of-the-webcam-input>"
            },
            "VpnMonitor": {
                "EntityId": "<entityid-of-the-vpn-monitor-input>",
                "NetworkInterfaceDescription": "<description-of-the-network-interface-to-monitor>"
            },
            "TcpPortMonitor": {
                "Targets": [
                    {
                        "Name": "<name-of-the-target>",
                        "EntityId": "<entityid-of-the-input>",
                        "Host": "<hostname-or-ip-address-of-the-target>",
                        "Port": 3389,
                        "ScanIntervalSeconds": 30,
                        "TimeoutMilliseconds": 2000
                    }
                ]
            }
        },
        "PluginHost": {
            "RunAs": "System"
        },
        "UserSession": {
            "PipeName": "HomeAssistantLink.UserSession",
            "ConnectTimeoutMilliseconds": 2000
        },
        "ServiceSession": {
            "PipeName": "HomeAssistantLink.ServiceSession",
            "ConnectTimeoutMilliseconds": 2000
        },
        "Plugins": {
            "ShutDownPlugin": {
                "RunAs": "System",
                "DisplayName": "<display-name-for-the-shutdown-command>",
                "Command": "<shutdown-command>",
                "EntityId": "<entityid-of-the-pc-to-shutdown>"
            },
            "ScriptRunnerPlugin": {
                "Actions": [
                    {
                        "RunAs": "User",
                        "DisplayName": "<display-name-for-the-user-session-script>",
                        "EntityId": "<entityid-of-the-script-command>",
                        "Command": "<script-command>",
                        "ScriptPath": "<full-path-to-the-powershell-script>",
                        "TimeoutSeconds": 30
                    },
                    {
                        "RunAs": "System",
                        "DisplayName": "<display-name-for-the-system-script>",
                        "EntityId": "<entityid-of-the-system-script-command>",
                        "Command": "<system-script-command>",
                        "ScriptPath": "<full-path-to-the-system-safe-powershell-script>",
                        "TimeoutSeconds": 30
                    }
                ]
            }
        }
    }
}
