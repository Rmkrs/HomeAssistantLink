{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "EventLog": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5421"
      }
    }
  },
  "HomeAssistantLink": {
    "HomeAssistant": {
      "Host": "<enter-your-homeassistant-url-here>",
      "ApiKey": "<enter-your-homeassistant-rest-apikey-here>"
    },
    "Api": {
      "Key" :  "<enter-your-local-api-key-here>"
    },
    "Monitors": {
      "WebCamMonitor": {
        "EntityId": "<entityid-of-the-webcam-input>"
      },
      "VpnMonitor": {
        "EntityId": "<entityid-of-the-vpn-monitor-input>",
        "NetworkInterfaceDescription": "<description-of-the-network-interface-to-monitor>"
      }
    },
    "Plugins": {
      "ShutDownPlugin": {
        "Command": "<shutdown-command>",
        "EntityId": "<entityid-of-the-pc-to-shutdown>"
      }
    }
  }
}
